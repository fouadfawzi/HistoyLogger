{
    "name": "fouadfawzi/history-logger",
    "description": "Track model changes and keep full JSON snapshots in a history table.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "history",
        "audit",
        "logger"
    ],
    "autoload": {
        "psr-4": {
            "FouadFawzi\\HistoryLogger\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FouadFawzi\\HistoryLogger\\HistoryLoggerServiceProvider"
            ]
        }
    },
    "authors": [
        {
            "name": "Fouad Fawzi",
            "email": "fouadfawzi.me@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.0",
        "illuminate/console": "^8.75|^9.0|^10.0|^11.0|^12.0",
        "illuminate/database": "^8.75|^9.0|^10.0|^11.0|^12.0",
        "illuminate/support": "^8.75|^9.0|^10.0|^11.0|^12.0"
    }
}
